# ===================== AI 模型配置 =====================
# 系统会按以下优先级自动检测：DeepSeek > Gemini > Groq > 通义千问 > OpenAI
# 只需填写你拥有的 Key，无需全部填写

# ── 推荐：DeepSeek（性价比最高，比 GPT-4o 便宜约 30 倍，中文效果极佳）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 备选：通义千问（同时用于内容审核，中文场景推荐）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 备选：Google Gemini Flash（速度快，价格低）
# 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 备选：Groq（有免费额度，速度极快）
# 获取地址：https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 兜底：OpenAI（默认不推荐，价格较高）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================== 内容审核配置 =====================
# DASHSCOPE_API_KEY 同时用于 Qwen 语义审核
# 未配置时，Layer 2 审核会跳过，仅执行本地敏感词检测（Layer 1）
# 阿里云内容安全 CIP 服务通过 X-DashScope-DataInspection Header 自动启用

# ===================== 数据库配置（可选）=====================
# 默认使用 SQLite，无需配置
# DATABASE_URL=sqlite:///./db/media_auto.db

# ===================== 持久化存储配置 =====================
# Railway Volume 挂载路径，数据库文件将存储在此目录下
# Railway 部署时：在控制台创建 Volume 并挂载到 /data，此变量无需手动设置
# 本地开发时：留空即可，数据库默认存储在项目 db/ 目录
DATA_DIR=/data

# ===================== 服务配置 =====================
PORT=8000
HOST=0.0.0.0
